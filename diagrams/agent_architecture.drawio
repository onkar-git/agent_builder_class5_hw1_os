        <mxCell id="111" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.75;exitY=1;entryX=0.5;entryY=0;fontSize=10;strokeColor=#82b366;strokeWidth=2.5;" edge="1" parent="1" source="10" target="31">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Tools -> Stores -->
        <mxCell id="120" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;" edge="1" parent="1" source="30" target="40">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="121" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;" edge="1" parent="1" source="31" target="41">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Agent -> Logging -->
        <mxCell id="130" value="trace each step" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.05;fontSize=10;strokeColor=#d79b00;dashed=1;" edge="1" parent="1" source="10" target="50">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="200" value="Legend" style="swimlane;startSize=24;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="990" width="1540" height="160" as="geometry" />
        </mxCell>
        <mxCell id="201" value="User" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="200">
          <mxGeometry x="20" y="40" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="202" value="Agent (orchestrator)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1f3b73;strokeColor=#1f3b73;fontColor=#ffffff;fontSize=10;" vertex="1" parent="200">
          <mxGeometry x="20" y="80" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="203" value="Agent property" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="200">
          <mxGeometry x="200" y="40" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="204" value="ReAct step (Thought/Action/Obs)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="200">
          <mxGeometry x="200" y="80" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="205" value="@tool function" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4e7e3;strokeColor=#3d8b85;fontSize=10;" vertex="1" parent="200">
          <mxGeometry x="420" y="40" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="206" value="Backing data store" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="200">
          <mxGeometry x="420" y="80" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="207" value="Trace / log entry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e0;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="200">
          <mxGeometry x="600" y="40" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="208" value="Final answer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="200">
          <mxGeometry x="600" y="80" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="209" value="&lt;b&gt;Stack&lt;/b&gt;&#xa;LLM: gpt-4o-mini (via langchain-openai, .bind_tools)&#xa;Tools: 2 plain Python functions decorated with @tool&#xa;Loop: hand-written manual ReAct (~25 lines of Python)&#xa;Data: SQLite (.db) + JSON (.json) - no fancy infra needed" style="text;html=1;align=left;verticalAlign=top;fontSize=10;spacing=6;" vertex="1" parent="200">
          <mxGeometry x="780" y="40" width="740" height="100" as="geometry" />
        </mxCell>

