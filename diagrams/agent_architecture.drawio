<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="29.7.9">
  <diagram name="Multi-tool ReAct Agent">
    <mxGraphModel dx="2400" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="Class 2: Multi-tool ReAct Agent (SpaceX)" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1f3b73;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="2120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3" value="One agent class. Two tools. The LLM decides which to call, in what order, and when to stop." style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="2120" height="22" as="geometry" />
        </mxCell>

        <!-- User -->
        <mxCell id="4" value="&lt;b&gt;User&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="140" height="80" as="geometry" />
        </mxCell>

        <!-- Question callout -->
        <mxCell id="5" value="&lt;b&gt;Example question&lt;/b&gt;&#xa;&quot;What is the thrust of the rocket&#xa;we use for crewed missions?&quot;&#xa;&#xa;The pipeline cannot answer this. The SQL&#xa;database has the rocket name. The JSON has&#xa;the thrust. Need both, in order." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="210" y="100" width="480" height="140" as="geometry" />
        </mxCell>

        <!-- Agent swimlane -->
        <mxCell id="10" value="Agent (one Python function with a loop)" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#1f3b73;fontColor=#ffffff;fontStyle=1;strokeColor=#1f3b73;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="720" y="100" width="820" height="450" as="geometry" />
        </mxCell>

        <!-- Agent properties -->
        <mxCell id="11" value="ChatOpenAI&#xa;(.bind_tools)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="10">
          <mxGeometry x="20" y="50" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="12" value="Tool registry&#xa;(2 tools)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="10">
          <mxGeometry x="220" y="50" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="13" value="messages list&#xa;(grows each step)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="10">
          <mxGeometry x="420" y="50" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="14" value="max_iters = 8&#xa;(safety valve)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="10">
          <mxGeometry x="620" y="50" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- ReAct loop label -->
        <mxCell id="15" value="ReAct loop  (run until LLM emits no tool_calls)" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="10">
          <mxGeometry x="20" y="120" width="780" height="20" as="geometry" />
        </mxCell>

        <!-- 3 ellipses -->
        <mxCell id="16" value="&lt;b&gt;Thought&lt;/b&gt;&#xa;reason about&#xa;next step" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="10">
          <mxGeometry x="60" y="160" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="17" value="&lt;b&gt;Action&lt;/b&gt;&#xa;LLM emits&#xa;tool_call" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="10">
          <mxGeometry x="320" y="160" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="18" value="&lt;b&gt;Observation&lt;/b&gt;&#xa;tool result&#xa;appended" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="10">
          <mxGeometry x="580" y="160" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Loop edges inside agent -->
        <mxCell id="19" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;endArrow=block;" edge="1" parent="10" source="16" target="17">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="20" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;endArrow=block;" edge="1" parent="10" source="17" target="18">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="21" value="repeat" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=1;curved=1;fontSize=10;strokeColor=#82b366;dashed=1;" edge="1" parent="10" source="18" target="16">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="670" y="280" />
              <mxPoint x="150" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Final answer banner -->
        <mxCell id="22" value="&lt;b&gt;no tool_calls -&gt; emit Final Answer (final string)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="10">
          <mxGeometry x="20" y="350" width="780" height="50" as="geometry" />
        </mxCell>

        <mxCell id="23" value="when done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=1;entryX=0.05;entryY=0;fontSize=10;dashed=1;strokeColor=#d79b00;" edge="1" parent="10" source="16" target="22">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Tools row (2 tools) -->
        <mxCell id="30" value="&lt;b&gt;@tool query_launches&lt;/b&gt;&#xa;sql: str  &#x2192;  rows (JSON)&#xa;&#xa;Read-only SELECT on launches table.&#xa;Same FORBIDDEN list and LIMIT injection&#xa;as the pipeline's validator." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4e7e3;strokeColor=#3d8b85;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="380" y="640" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="31" value="&lt;b&gt;@tool vehicle_specs&lt;/b&gt;&#xa;vehicle: str  &#x2192;  spec sheet (JSON)&#xa;&#xa;Lookup in vehicle_specs.json.&#xa;Returns thrust, height, mass, payload_to_leo,&#xa;reusable, active, first_flight, notes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4e7e3;strokeColor=#3d8b85;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="640" width="360" height="120" as="geometry" />
        </mxCell>

        <!-- Step badges -->
        <mxCell id="32" value="step 1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#5d8a4a;fontSize=10;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="510" y="630" width="60" height="28" as="geometry" />
        </mxCell>
        <mxCell id="33" value="step 2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#5d8a4a;fontSize=10;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="930" y="630" width="60" height="28" as="geometry" />
        </mxCell>

        <!-- Stores row -->
        <mxCell id="40" value="&lt;b&gt;spacex_launches.db&lt;/b&gt;&#xa;SQLite&#xa;launches table&#xa;18 rows" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="830" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="41" value="&lt;b&gt;vehicle_specs.json&lt;/b&gt;&#xa;file on disk&#xa;keyed by vehicle name&#xa;4 rockets" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff4e0;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="830" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- Tracing panel -->
        <mxCell id="50" value="Trace of the example question" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#fff4e0;strokeColor=#d79b00;fontSize=12;fontStyle=1;fontColor=#7a4f00;align=center;" vertex="1" parent="1">
          <mxGeometry x="1620" y="100" width="540" height="850" as="geometry" />
        </mxCell>

        <mxCell id="51" value="&lt;b&gt;step 1 &#xb7; thought&lt;/b&gt;&#xa;Need to find which rocket flies crewed&#xa;missions. Call query_launches." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="50">
          <mxGeometry x="20" y="50" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="52" value="&lt;b&gt;step 1 &#xb7; action&lt;/b&gt;&#xa;query_launches(&quot;SELECT DISTINCT vehicle&#xa;FROM launches WHERE payload_type = 'Crew'&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=top;spacing=6;fontStyle=1;" vertex="1" parent="50">
          <mxGeometry x="20" y="120" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="53" value="&lt;b&gt;step 1 &#xb7; observation&lt;/b&gt;&#xa;[{&quot;vehicle&quot;: &quot;Falcon 9&quot;}]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="50">
          <mxGeometry x="20" y="190" width="500" height="50" as="geometry" />
        </mxCell>

        <mxCell id="54" value="&lt;b&gt;step 2 &#xb7; thought&lt;/b&gt;&#xa;Falcon 9. Now look up its thrust." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="50">
          <mxGeometry x="20" y="260" width="500" height="50" as="geometry" />
        </mxCell>
        <mxCell id="55" value="&lt;b&gt;step 2 &#xb7; action&lt;/b&gt;&#xa;vehicle_specs(&quot;Falcon 9&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=top;spacing=6;fontStyle=1;" vertex="1" parent="50">
          <mxGeometry x="20" y="320" width="500" height="50" as="geometry" />
        </mxCell>
        <mxCell id="56" value="&lt;b&gt;step 2 &#xb7; observation&lt;/b&gt;&#xa;{thrust_kn: 7607, height_m: 70, mass_kg: 549054,&#xa; payload_to_leo_kg: 22800, reusable: true, ...}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="50">
          <mxGeometry x="20" y="380" width="500" height="60" as="geometry" />
        </mxCell>

        <mxCell id="57" value="&lt;b&gt;step 3 &#xb7; thought&lt;/b&gt;&#xa;Have rocket name and thrust. Compose answer." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="50">
          <mxGeometry x="20" y="450" width="500" height="50" as="geometry" />
        </mxCell>

        <mxCell id="58" value="&lt;b&gt;Final Answer&lt;/b&gt;&#xa;The rocket used for crewed missions is the&#xa;Falcon 9, which has a thrust of 7,607 kN." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;fontStyle=1;" vertex="1" parent="50">
          <mxGeometry x="20" y="510" width="500" height="60" as="geometry" />
        </mxCell>

        <mxCell id="59" value="3 LLM calls. 2 tool calls. The LLM picked the order. We did not write any if-else." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#7a4f00;" vertex="1" parent="50">
          <mxGeometry x="20" y="600" width="500" height="40" as="geometry" />
        </mxCell>

        <mxCell id="60" value="&lt;b&gt;In a pipeline:&lt;/b&gt; we would have to write the if-else by hand. With every new question type we would add another branch. With every new data source, every branch would need updating. The agent absorbs that complexity into the LLM's decision." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="50">
          <mxGeometry x="20" y="660" width="500" height="120" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="100" value="question" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.9;exitY=0;entryX=0.05;entryY=0;fontSize=11;strokeWidth=1.5;" edge="1" parent="1" source="4" target="10">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="166" y="80" />
              <mxPoint x="761" y="80" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="101" value="final answer" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.8;entryX=0.5;entryY=1;fontSize=11;strokeColor=#d79b00;strokeWidth=2;dashed=1;" edge="1" parent="1" source="10" target="4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Agent -> Tools -->
        <mxCell id="110" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;fontSize=10;strokeColor=#82b366;strokeWidth=2.5;" edge="1" parent="1" source="10" target="30">
          <mxGeometry relative="1" as="geometry" />
