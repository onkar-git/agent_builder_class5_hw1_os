<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="29.7.9">
  <diagram name="NL to SQL Pipeline">
    <mxGraphModel dx="2000" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1860" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="Class 1: NL to SQL Pipeline (SpaceX launches)" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1f3b73;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1780" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3" value="Six fixed steps, two LLM calls, one SQLite call. The same order every time." style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1780" height="22" as="geometry" />
        </mxCell>

        <!-- schema.md note (top, anchored above Generator) -->
        <mxCell id="10" value="&lt;b&gt;schema.md&lt;/b&gt; (read once at startup)&#xa;- DDL from sqlite_master&#xa;- Column descriptions + allowed values&#xa;- Domain terms (heavy launch, civilian mission)&#xa;- 5 few-shot NL&#x2192;SQL examples" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e0;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="240" y="100" width="320" height="110" as="geometry" />
        </mxCell>

        <!-- summary system prompt note (above summarizer) -->
        <mxCell id="11" value="&lt;b&gt;Summary system prompt&lt;/b&gt;&#xa;&quot;Answer in one sentence. Cite numbers&#xa;exactly. Do not speculate. If rows is empty,&#xa;say you couldn&apos;t find an answer.&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e0;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1180" y="100" width="320" height="110" as="geometry" />
        </mxCell>

        <!-- Pipeline boxes -->
        <mxCell id="20" value="&lt;b&gt;User&lt;/b&gt;&#xa;&#xa;&quot;How many heavy&#xa;launches have we&#xa;flown?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="160" height="120" as="geometry" />
        </mxCell>

        <mxCell id="21" value="&lt;b&gt;LLM Generator&lt;/b&gt;&#xa;&#xa;Question + schema.md&#xa;&#x2192; SQL string&#xa;&#xa;ChatOpenAI&#xa;temperature = 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="260" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="22" value="&lt;b&gt;Validator&lt;/b&gt;&#xa;&#xa;- Reject INSERT/&#xa;UPDATE/DELETE/DROP&#xa;- Require FROM launches&#xa;- Inject LIMIT 100" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="260" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="23" value="&lt;b&gt;SQLite Executor&lt;/b&gt;&#xa;&#xa;sqlite3.connect(DB)&#xa;.execute(sql)&#xa;.fetchall()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="260" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="24" value="&lt;b&gt;spacex_launches.db&lt;/b&gt;&#xa;&#xa;launches table&#xa;18 rows" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="450" width="160" height="120" as="geometry" />
        </mxCell>

        <mxCell id="25" value="&lt;b&gt;LLM Summarizer&lt;/b&gt;&#xa;&#xa;Question + rows&#xa;&#x2192; English answer&#xa;&#xa;ChatOpenAI&#xa;temperature = 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1060" y="260" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="26" value="&lt;b&gt;User receives answer&lt;/b&gt;&#xa;&#xa;&quot;We have flown 6 heavy&#xa;launches (payload &gt; 5,000 kg).&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1320" y="260" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="30" value="NL question" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;" edge="1" parent="1" source="20" target="21">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="31" value="SQL string" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;" edge="1" parent="1" source="21" target="22">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="32" value="validated SQL" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;" edge="1" parent="1" source="22" target="23">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="33" value="execute" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.4;exitY=1;entryX=0.4;entryY=0;fontSize=10;" edge="1" parent="1" source="23" target="24">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="34" value="rows" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.7;exitY=0;entryX=0.7;entryY=1;fontSize=10;" edge="1" parent="1" source="24" target="23">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="35" value="rows + question" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;" edge="1" parent="1" source="23" target="25">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="36" value="NL answer" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;" edge="1" parent="1" source="25" target="26">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Annotation edges (dashed) -->
        <mxCell id="40" value="loaded into prompt" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=open;startArrow=none;strokeColor=#d79b00;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;fontColor=#7a4f00;" edge="1" parent="1" source="10" target="21">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="41" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=open;startArrow=none;strokeColor=#d79b00;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="11" target="25">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Test suite block -->
        <mxCell id="50" value="The test suite (drives this whole class)" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#fff4e0;strokeColor=#d79b00;fontSize=13;fontStyle=1;fontColor=#7a4f00;" vertex="1" parent="1">
          <mxGeometry x="40" y="640" width="1130" height="220" as="geometry" />
        </mxCell>
        <mxCell id="51" value="&lt;b&gt;test_suite&lt;/b&gt; = list of dicts:&#xa;{&#xa;  question, expected_sql, expected_answer&#xa;}&#xa;&#xa;The test suite is the contract.&#xa;A prompt change is &apos;better&apos; only if the&#xa;test suite says it is." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="50">
          <mxGeometry x="20" y="50" width="280" height="160" as="geometry" />
        </mxCell>
        <mxCell id="52" value="&lt;b&gt;v1: DDL only&lt;/b&gt;&#xa;extracted via&#xa;sqlite_master.&#xa;Pass: 3/5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="50">
          <mxGeometry x="320" y="50" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="53" value="&lt;b&gt;v2: + descriptions&lt;/b&gt;&#xa;column meanings,&#xa;allowed values,&#xa;conventions.&#xa;Pass: 3/5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="50">
          <mxGeometry x="580" y="50" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="54" value="&lt;b&gt;v3: + domain terms + few-shot&lt;/b&gt;&#xa;the full schema.md.&#xa;Pass: 5/5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="50">
          <mxGeometry x="840" y="50" width="270" height="80" as="geometry" />
        </mxCell>
        <mxCell id="55" value="&lt;b&gt;Lesson:&lt;/b&gt; for 'How many heavy launches?', v1 and v2 both write WHERE vehicle = 'Falcon Heavy' (returns 2). v3 has the term defined as payload_kg &gt; 5000 (returns 6). When business vocabulary collides with column values, the LLM picks the wrong reading unless you write the term down." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=2;fontColor=#7a4f00;spacing=6;" vertex="1" parent="50">
          <mxGeometry x="320" y="140" width="790" height="70" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="60" value="Legend" style="swimlane;startSize=24;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="640" width="620" height="220" as="geometry" />
        </mxCell>
        <mxCell id="61" value="User input / output" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="60">
          <mxGeometry x="20" y="40" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="62" value="LLM call" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="60">
          <mxGeometry x="20" y="80" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="63" value="Validation / control" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="60">
          <mxGeometry x="20" y="120" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="64" value="Execution / I/O" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="60">
          <mxGeometry x="220" y="40" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="65" value="Database (cylinder)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="60">
          <mxGeometry x="220" y="80" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="66" value="Notes / annotations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e0;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="60">
          <mxGeometry x="220" y="150" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="67" value="&lt;b&gt;Stack&lt;/b&gt;&#xa;LLM: gpt-4o-mini via langchain-openai&#xa;DB: SQLite (file on disk)&#xa;Schema doc: schema.md (markdown)&#xa;~75 lines of Python total." style="text;html=1;align=left;verticalAlign=top;fontSize=10;spacing=4;" vertex="1" parent="60">
          <mxGeometry x="420" y="40" width="180" height="160" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
